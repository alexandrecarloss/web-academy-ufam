<div class='d-flex align-items-center justify-content-between'>
  <h4>{{product.name}}</h4>
  <h4><a href='/products/create'><i class='bi bi-plus-square'></i></a></h4>
</div>
<div class='card' style='width: 18rem;'>
  <div class='card-body'>
    <p class='card-text'><strong>Preço: </strong>{{product.price}}</p>
    <p class='card-text'><strong>Quantidade: </strong>{{product.stock}}</p>
    <a href='/products/update/{{product.id}}' class='card-link'><i
        class='bi bi-pencil'
      ></i></a>
    <a
      href='#'
      class='card-link text-danger'
      data-bs-toggle='modal'
      data-bs-target='#deleteModal'
      onclick="prepareDelete('{{id}}', '{{name}}')"
    >
      <i class='bi bi-trash'></i>
    </a>
    <a href='/products' class='card-link'>Voltar</a>
  </div>
  {{> deleteModal}}
</div>